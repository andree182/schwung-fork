    },
    {
      "title": "Modes",
      "lines": [
        "Splitter: sends",
        "splits to pipes.",
        "Receiver: replays",
        "MIDI from pipes."
      ]
    },
    {
      "title": "Menus",
      "children": [
        {
          "title": "Global",
          "lines": [
            "Mode: split/recv",
            "Transpose: oct",
            "transpose for",
            "main & received",
            "notes.",
            "Recv Pipe: select",
            "input source."
          ]
        },
        {
          "title": "Splits 1, 2, 3",
          "lines": [
            "Oct: split point",
            "Chan: new channel",
